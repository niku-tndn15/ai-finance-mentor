# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and is loaded automatically by Next.js and by
# the `db:*` / `prisma:*` npm scripts (via dotenv-cli).
# In deployed environments (Netlify), set these in the Netlify UI instead
# (Site settings → Environment variables) per deploy context.

# --- Database (Supabase Postgres) — TECH_STACK.md §6 ---
# Pooled connection (pgbouncer, port 6543) — used by the running app.
DATABASE_URL="postgresql://postgres:password@db.example.supabase.co:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used only for Prisma migrations.
DIRECT_URL="postgresql://postgres:password@db.example.supabase.co:5432/postgres"

# --- Auth ---
# Random 32+ byte secret used to sign session tokens. Generate with:
# openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-secret"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Verified sender for auth emails. Defaults to Resend's sandbox sender if unset.
# Set to your verified domain sender in production, e.g. "UrPaisa <hello@urpaisa.app>".
EMAIL_FROM="UrPaisa <onboarding@resend.dev>"

# --- AI (OpenAI) — TECH_STACK.md §5 ---
# Optional: with no real key (or the placeholder below) the app runs entirely on
# deterministic fallback templates (PRD 05 §8) — AI only makes copy friendlier.
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AI_MODEL_FAST="gpt-4o-mini"
AI_MODEL_REASONING="gpt-4o"

# --- Scheduled jobs (Netlify Scheduled Functions) ---
# Shared secret the scheduled crons send as a bearer token to their generate
# routes: daily nudge (/api/nudges/generate), weekly reflection
# (/api/reflections/generate), and monthly reset (/api/resets/generate).
# Generate with: openssl rand -base64 32
CRON_SECRET="replace-with-a-long-random-secret"

# --- Error monitoring (Sentry) ---
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- Analytics (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
